{
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(basedpyright:*)",
      "Bash(uv pip install:*)",
      "Bash(uv venv:*)",
      "Bash(uv sync:*)",
      "Bash(diet --root:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.py) cd \"$CLAUDE_PROJECT_DIR\" && ./.venv/bin/ruff check \"$f\" ;; esac"
          }
        ]
      }
    ]
  }
}
